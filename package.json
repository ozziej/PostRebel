{
  "name": "postrebel",
  "version": "1.0.0",
  "description": "Local API testing tool with git support",
  "author": "James Ostrowick <james@ostrowick.co.za>",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:electron\" \"npm run dev:react\"",
    "dev:react": "webpack serve --mode development",
    "dev:electron": "npm run build:electron && wait-on http://localhost:3000 && NODE_ENV=development npx electron .",
    "build": "npm run build:react && npm run build:electron",
    "build:react": "webpack --mode production",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.0.0",
    "css-loader": "^7.0.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.0.0",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.0",
    "wait-on": "^9.0.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^6.0.0",
    "webpack-dev-server": "^5.0.0"
  },
  "build": {
    "appId": "com.postrebel.app",
    "productName": "PostRebel",
    "directories": {
      "output": "release"
    },
    "mac": {
      "icon": "assets/icon.icns",
      "notarize": true
    },
    "win": {
      "icon": "assets/SquareLogo.png",
      "target": ["nsis"]
    },
    "linux": {
      "icon": "assets/SquareLogo.png",
      "target": ["AppImage", "deb"],
      "category": "Development"
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "jsonlint-mod": "^1.7.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "simple-git": "^3.21.0"
  }
}
